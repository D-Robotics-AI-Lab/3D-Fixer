{
    "models": {
        "denoiser": {
            "name": "SceneSparseStructureFlowModule",
            "args": {
                "resolution": 16,
                "in_channels": 8,
                "out_channels": 8,
                "model_channels": 1024,
                "cond_channels": 1024,
                "num_blocks": 12,
                "num_heads": 16,
                "mlp_ratio": 4,
                "patch_size": 1,
                "pe_mode": "ape",
                "qk_rms_norm": true,
                "use_fp16": true,
                "use_checkpoint": true,
                "resume_ckpts": "path/to/pre-trained-models"
            }
        },
        "frozen_denoiser": {
            "name": "SparseStructureFlowModel",
            "args": {
                "frozen": true,
                "resolution": 16,
                "in_channels": 8,
                "out_channels": 8,
                "model_channels": 1024,
                "cond_channels": 1024,
                "num_blocks": 24,
                "num_heads": 16,
                "mlp_ratio": 4,
                "patch_size": 1,
                "pe_mode": "ape",
                "qk_rms_norm": true,
                "use_fp16": true,
                "use_checkpoint": true,
                "pretrained_ss_flow_dit": "path/to/pre-trained-models"
            }
        },
        "encoder": {
            "name": "SparseStructureEncoder",
            "args": {
                "frozen": true,
                "in_channels": 1,
                "latent_channels": 8,
                "num_res_blocks": 2,
                "num_res_blocks_middle": 2,
                "channels": [32, 128, 512],
                "use_fp16": true,
                "pretrained_ss_enc": "microsoft/TRELLIS-image-large/ckpts/ss_enc_conv3d_16l8_fp16"
            }
        }
    },
    "dataset": {
        "name": "SceneImageConditionedVoxel",
        "args": {
            "latent_model": "ss_enc_conv3d_16l8_fp16",
            "min_aesthetic_score": 4.5,
            "image_size": 1024,
            "crop_size": 518,
            "erode_kernel_size": 7,
            "stage": "fine",
            "erode_iters": 2,
            "pretrained_ss_dec": "microsoft/TRELLIS-image-large/ckpts/ss_dec_conv3d_16l8_fp16",
            "min_pixel_ratio": 0.005,
            "est_depth_folder": ["depth_MoGeV2", "depth_DAv2_vitl", "depth_ml-depth-pro", "depth_VGGT_1B"],
            "perturb_scale_min": 0.9,
            "perturb_scale_max": 1.1,
            "perturb_trans_factor": 0.05,
            "perturb_rot_angles": 180.0,
            "max_mesh_size": 5.0,
            "resize_perturb": true,
            "resize_perturb_ratio": 0.5
        }
    },
    "trainer": {
        "name": "SceneImageConditionedFlowMatchingCFGTrainer",
        "args": {
            "max_steps": 150000,
            "batch_size_per_gpu": 4,
            "batch_split": 4,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 1e-5,
                    "weight_decay": 0.0
                }
            },
            "ema_rate": [
                0.9999
            ],
            "fp16_mode": "inflat_all",
            "fp16_scale_growth": 0.001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "i_print": 100,
            "i_log": 100,
            "i_sample": 5000,
            "i_save": 5000,
            "p_uncond": 0.1,
            "t_schedule": {
                "name": "logitNormal",
                "args": {
                    "mean": 1.0,
                    "std": 1.0
                }
            },
            "sigma_min": 1e-5,
            "align_loss_weight": 0.5,
            "image_cond_model": "dinov2_vitl14_reg",
            "moge_ckpts": "Ruicheng/moge-2-vitl",
            "online_encode_z0": true
        }
    }
}